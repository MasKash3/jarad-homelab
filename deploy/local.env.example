# Optional local deploy values for your machine.
# Copy to deploy/local.env and keep the copy out of Git.

JARAD_DEPLOY_HOST="<server-ip-or-host>"
JARAD_DEPLOY_USER="<ssh-user>"
JARAD_REMOTE_ROOT="~/mobile"
JARAD_CADDY_DOMAIN="<device.tailnet.ts.net>"
JARAD_CADDY_APP_PORT="8444"
JARAD_CADDYFILE="~/caddy/Caddyfile"
