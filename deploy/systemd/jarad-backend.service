[Unit]
Description=Jarad Backend
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=__USER__
Group=__USER__
WorkingDirectory=__REMOTE_ROOT__/backend
Environment=JARAD_BACKEND_HOST=127.0.0.1
Environment=JARAD_BACKEND_PORT=8443
Environment=JARAD_DOCKER_HELPER=/usr/local/sbin/jarad-docker
EnvironmentFile=-__REMOTE_ROOT__/backend/.env
ExecStart=__REMOTE_ROOT__/backend/.venv/bin/uvicorn jarad_backend.main:app --host ${JARAD_BACKEND_HOST} --port ${JARAD_BACKEND_PORT}
Restart=on-failure
RestartSec=5
UMask=0077
# DNS access enforcement uses sudoers to allow only the narrow jarad-dns-access helper.
NoNewPrivileges=false
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=__REMOTE_ROOT__/backend
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictSUIDSGID=true
LockPersonality=true
RestrictRealtime=true
SystemCallArchitectures=native

[Install]
WantedBy=multi-user.target
