# Required in real use. The frontend sends this as:
# Authorization: Bearer <token>
JARAD_APP_TOKEN=change-this-long-random-token
# Optional local development escape hatch. Do not enable on the server.
JARAD_ALLOW_INSECURE_DEFAULTS=0

# Base32 secret for authenticator app TOTP codes.
# Generate one with: python3 -c "import base64, secrets; print(base64.b32encode(secrets.token_bytes(20)).decode().rstrip('='))"
JARAD_TOTP_SECRET=CHANGE_THIS_BASE32_TOTP_SECRET

# Network identity
JARAD_PUBLIC_HOST=jarad.example.ts.net
JARAD_LAN_IP=10.0.0.10
JARAD_ALLOWED_ORIGINS=http://127.0.0.1:5178,http://localhost:5178,http://10.0.0.10:5178,https://jarad.example.ts.net:8444

# Service bind settings for systemd. Keep these on localhost when using Caddy.
JARAD_BACKEND_HOST=127.0.0.1
JARAD_BACKEND_PORT=8443
JARAD_FRONTEND_HOST=127.0.0.1
JARAD_FRONTEND_PORT=5178

# Server paths
JARAD_DATA_MOUNT=/mnt/data
JARAD_BACKUP_LOG=/var/log/server-backup.log
JARAD_DNS_SERVER=10.0.0.10
