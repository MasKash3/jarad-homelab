# Required in real use. The frontend sends this as:
# Authorization: Bearer <token>
JARAD_APP_TOKEN=change-this-long-random-token
# Optional local development escape hatch. Do not enable on the server.
JARAD_ALLOW_INSECURE_DEFAULTS=0

# Base32 secret for authenticator app TOTP codes.
# Generate one with: python3 -c "import base64, secrets; print(base64.b32encode(secrets.token_bytes(20)).decode().rstrip('='))"
JARAD_TOTP_SECRET=CHANGE_THIS_BASE32_TOTP_SECRET
# Optional emergency bootstrap mode if no TOTP secret exists yet. Do not enable on the server during normal use.
JARAD_ALLOW_PASSKEY_BOOTSTRAP_WITHOUT_TOTP=0
# Per-device bearer tokens expire and should be rotated periodically.
JARAD_DEVICE_TOKEN_TTL_DAYS=90
# Short-lived browser sessions are derived from registered device tokens.
JARAD_BROWSER_SESSION_TTL_MINUTES=30

# Network identity
JARAD_PUBLIC_HOST=app.example.com
JARAD_SERVICE_DOMAIN=example.com
JARAD_LAN_IP=10.0.0.10
# Production must use this one exact HTTPS origin. Local development may additionally use explicit localhost/127.0.0.1 origins.
JARAD_ALLOWED_ORIGINS=https://app.example.com
JARAD_WEBAUTHN_RP_ID=app.example.com
JARAD_WEBAUTHN_ORIGIN=https://app.example.com
JARAD_DB_PATH=./jarad.sqlite3

# Service bind settings for systemd. Keep these on localhost when using Caddy.
JARAD_BACKEND_HOST=127.0.0.1
JARAD_BACKEND_PORT=8443
JARAD_FRONTEND_HOST=127.0.0.1
JARAD_FRONTEND_PORT=5178

# Server paths
JARAD_DATA_MOUNT=/mnt/data
JARAD_BACKUP_LOG=/var/log/server-backup.log
JARAD_DNS_SERVER=10.0.0.10

# Optional Pi-hole DNS client approval. Keep disabled until approved clients are seeded on the server.
JARAD_DNS_ACCESS_ENABLED=0
JARAD_DNS_LAN_SUBNET=10.0.0.0/24
JARAD_DNS_SERVER_IP=10.0.0.10
JARAD_DNS_ACCESS_HELPER=/usr/local/sbin/jarad-dns-access
